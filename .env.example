# ==================== TikTok视频智能拆解助手 ====================
# 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# ==================== API密钥配置 ====================

# TikWM API - TikTok视频下载
# 获取地址: https://rapidapi.com/tikwm/api/tiktok-video-details
# 注册后可在 RapidAPI 平台获取
TIKWM_API_KEY=your_tikwm_api_key_here

# Google Cloud Speech-to-Text - 语音转文字
# 获取地址: https://cloud.google.com/speech-to-text
# 1. 创建 Google Cloud 项目 (https://console.cloud.google.com)
# 2. 启用 Cloud Speech-to-Text API
# 3. 创建服务账号，下载JSON密钥文件
# 4. 将JSON文件内容直接粘贴到这里（保持JSON格式）
GOOGLE_APPLICATION_CREDENTIALS={"type": "service_account", "project_id": "...", ...}

# 阿里云视觉智能 - OCR识别和画面分析
# 获取地址: https://vision.aliyun.com
# 1. 注册阿里云账号
# 2. 开通视觉智能开放平台
# 3. 创建AccessKey
ALIYUN_VISION_ACCESS_KEY=your_access_key_here
ALIYUN_VISION_SECRET_KEY=your_secret_key_here

# 通义千问 - 大语言模型话术分析
# 获取地址: https://dashscope.console.aliyun.com
# 1. 注册阿里云账号
# 2. 开通模型服务
# 3. 创建API Key
TONGYI_QIANWEN_API_KEY=your_tongyi_api_key_here

# ==================== 应用配置 ====================

# 应用名称
APP_NAME=TikTok视频智能拆解助手

# 应用版本
APP_VERSION=1.0.0
